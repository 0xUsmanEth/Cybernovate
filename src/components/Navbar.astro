---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const active = (path: string) => {
  if (path === '/') return currentPath === '/';
  return currentPath.startsWith(path);
};
---
<header class="header" id="siteHeader">
  <div class="container header__inner">
    <a href="/" class="header__brand" aria-label="CyberNovate home">
      <img src="/assets/logo.png" alt="CyberNovate" class="header__logo" width="160" height="42" />
    </a>

    <nav class="nav" aria-label="Primary">
      <ul class="nav__list">
        <li><a href="/" class={`nav__link${active('/') ? ' is-active' : ''}`}>Home</a></li>

        <li class="nav__item--has-menu">
          <a href="/cybersecurity" class={`nav__link${active('/cybersecurity') ? ' is-active' : ''}`} aria-haspopup="true">
            Cybersecurity
            <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><path fill="currentColor" d="M5 7 1 3h8z"/></svg>
          </a>
          <div class="nav__submenu" role="menu">
            <a href="/cybersecurity/governance-risk-compliance" role="menuitem">Governance, Risk &amp; Compliance</a>
            <a href="/cybersecurity/consulting" role="menuitem">Cybersecurity Consulting</a>
            <a href="/cybersecurity/third-party-security" role="menuitem">Third-party Security Management</a>
            <a href="/cybersecurity/security-testing" role="menuitem">Security Testing &amp; Assessment</a>
            <a href="/cybersecurity/security-architecture" role="menuitem">Security Architecture &amp; Design</a>
            <a href="/cybersecurity/strategy-transformation" role="menuitem">Strategy &amp; Transformation</a>
          </div>
        </li>

        <li class="nav__item--has-menu">
          <a href="/applications" class={`nav__link${active('/applications') ? ' is-active' : ''}`} aria-haspopup="true">
            Applications
            <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true"><path fill="currentColor" d="M5 7 1 3h8z"/></svg>
          </a>
          <div class="nav__submenu" role="menu">
            <a href="/applications/business-intelligence" role="menuitem">Business Intelligence</a>
            <a href="/applications/system-integration" role="menuitem">System Integration</a>
            <a href="/applications/technology-consulting" role="menuitem">Technology Consulting</a>
            <a href="/applications/it-managed-services" role="menuitem">IT Managed Services</a>
            <a href="/applications/ai-for-business" role="menuitem">AI for Business</a>
          </div>
        </li>

        <li><a href="/ai-services" class={`nav__link${active('/ai-services') ? ' is-active' : ''}`}>AI Services</a></li>
        <li><a href="/about" class={`nav__link${active('/about') ? ' is-active' : ''}`}>About</a></li>
        <li><a href="/contact" class={`nav__link${active('/contact') ? ' is-active' : ''}`}>Contact</a></li>
      </ul>
    </nav>

    <a href="mailto:hello@cybernovate.io" class="header__email">
      <svg viewBox="0 0 24 24" width="14" height="14" aria-hidden="true"><path fill="currentColor" d="M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm0 2v.4l8 5 8-5V6H4Zm16 2.5-7.42 4.64a1 1 0 0 1-1.16 0L4 8.5V18h16V8.5Z"/></svg>
      hello@cybernovate.io
    </a>
    <a href="/contact" class="btn btn--primary header__cta"><span>Get a Quote</span></a>

    <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false" aria-controls="mobileNav">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile drawer — outside header to prevent scroll-width bleed -->
<nav class="mobile-nav" id="mobileNav" aria-label="Mobile navigation" aria-hidden="true">
  <ul class="mobile-nav__list">
    <li><a href="/">Home</a></li>

    <li class="mobile-nav__group">
      <button class="mobile-nav__toggle" aria-expanded="false" aria-controls="mnCybersecurity">
        Cybersecurity
        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M8 10.5 3 5.5h10z"/></svg>
      </button>
      <ul id="mnCybersecurity" class="mobile-nav__sub" hidden>
        <li><a href="/cybersecurity">All Cybersecurity Services</a></li>
        <li><a href="/cybersecurity/governance-risk-compliance" class="sub">Governance, Risk &amp; Compliance</a></li>
        <li><a href="/cybersecurity/consulting" class="sub">Cybersecurity Consulting</a></li>
        <li><a href="/cybersecurity/third-party-security" class="sub">Third-party Security</a></li>
        <li><a href="/cybersecurity/security-testing" class="sub">Security Testing &amp; Assessment</a></li>
        <li><a href="/cybersecurity/security-architecture" class="sub">Security Architecture &amp; Design</a></li>
        <li><a href="/cybersecurity/strategy-transformation" class="sub">Strategy &amp; Transformation</a></li>
      </ul>
    </li>

    <li class="mobile-nav__group">
      <button class="mobile-nav__toggle" aria-expanded="false" aria-controls="mnApplications">
        Applications
        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M8 10.5 3 5.5h10z"/></svg>
      </button>
      <ul id="mnApplications" class="mobile-nav__sub" hidden>
        <li><a href="/applications">All Application Services</a></li>
        <li><a href="/applications/business-intelligence" class="sub">Business Intelligence</a></li>
        <li><a href="/applications/system-integration" class="sub">System Integration</a></li>
        <li><a href="/applications/technology-consulting" class="sub">Technology Consulting</a></li>
        <li><a href="/applications/it-managed-services" class="sub">IT Managed Services</a></li>
        <li><a href="/applications/ai-for-business" class="sub">AI for Business</a></li>
      </ul>
    </li>

    <li class="mobile-nav__group">
      <button class="mobile-nav__toggle" aria-expanded="false" aria-controls="mnAiServices">
        AI Services
        <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path fill="currentColor" d="M8 10.5 3 5.5h10z"/></svg>
      </button>
      <ul id="mnAiServices" class="mobile-nav__sub" hidden>
        <li><a href="/ai-services">All AI Services</a></li>
        <li><a href="/ai-services/cybersecurity-for-ai" class="sub">Cybersecurity for AI</a></li>
        <li><a href="/ai-services/ai-cybersecurity-framework" class="sub">AI Cybersecurity Framework</a></li>
      </ul>
    </li>

    <li class="mobile-nav__group">
      <p class="mobile-nav__section">Company</p>
      <ul class="mobile-nav__sub" style="display:block">
        <li><a href="/about">About</a></li>
        <li><a href="/contact">Contact</a></li>
      </ul>
    </li>
  </ul>

  <a href="/contact" class="btn btn--primary mobile-nav__cta"><span>Get a Quote</span></a>
</nav>
