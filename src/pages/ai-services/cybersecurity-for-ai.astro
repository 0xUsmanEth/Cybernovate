---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import DetailCard from '../../components/DetailCard.astro';
import CTABanner from '../../components/CTABanner.astro';
---
<BaseLayout
  title="Cybersecurity for AI Solutions | CyberNovate"
  description="Protect AI solutions against misuse, compromise, and data exposure by embedding cybersecurity controls across the AI lifecycle."
>

  <PageHero eyebrow="AI Services" title="Cybersecurity for AI Solutions">
    <BreadcrumbNav slot="breadcrumb" crumbs={[
      { label: 'Home', href: '/' },
      { label: 'AI Services', href: '/ai-services' },
      { label: 'Cybersecurity for AI' },
    ]} />
    <Fragment slot="subtitle">
      <p>As organizations adopt artificial intelligence across business and security functions, they must ensure that AI solutions are protected against misuse, compromise, data exposure, and emerging threats. We help clients secure AI solutions by addressing the cybersecurity risks associated with AI design, development, deployment, integration, and ongoing operations.</p>
      <p>Our services help organizations build trust in AI technologies by embedding cybersecurity controls, governance, and risk management practices across the AI lifecycle.</p>
    </Fragment>
  </PageHero>

  <section class="sub-services" aria-labelledby="cyberAiTitle">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">What We Deliver</span>
        <h2 id="cyberAiTitle" class="section-title">Cybersecurity for AI Capabilities</h2>
      </header>
      <div class="sub-services__grid">

        <DetailCard
          title="Cybersecurity Assessments for AI Solutions and AI-enabled Platforms"
          description="We assess the cybersecurity posture of AI solutions and AI-enabled platforms to identify risks, control gaps, and exposure across design, data, and deployment dimensions."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M12 2 4 5v6c0 5 3.4 9.4 8 11 4.6-1.6 8-6 8-11V5l-8-3Z"/></svg>
        </DetailCard>

        <DetailCard
          title="Security Controls for AI Data, Models, Integrations, and Environments"
          description="We design and implement security controls that protect AI data pipelines, model assets, integration points, and the environments in which AI systems operate."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M3 3h8v8H3V3Zm10 0h8v8h-8V3ZM3 13h8v8H3v-8Zm10 0h8v8h-8v-8Z"/></svg>
        </DetailCard>

        <DetailCard
          title="Risk Identification for AI-specific Threats and Attack Scenarios"
          description="We identify and analyze AI-specific threats, including adversarial attacks, data poisoning, model theft, and prompt injection, to help organizations understand and manage emerging risks."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M12 2 1 21h22L12 2Zm0 4 7.5 13H4.5L12 6Zm-1 5v4h2v-4h-2Zm0 5v2h2v-2h-2Z"/></svg>
        </DetailCard>

        <DetailCard
          title="Guidance for Secure AI Development and Deployment Practices"
          description="We provide practical guidance on secure AI development practices, deployment standards, and operational controls to reduce risk throughout the AI lifecycle."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm-1 1.5L18.5 9H13V3.5ZM8 13h8v2H8v-2Zm0-4h5v2H8V9Zm0 8h8v2H8v-2Z"/></svg>
        </DetailCard>

        <DetailCard
          title="Ongoing Security Recommendations Across the AI Lifecycle"
          description="We deliver continuous security recommendations aligned to the evolving AI threat landscape, helping organizations stay protected as AI systems and risks develop."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M12 4V1L8 5l4 4V6c3.31 0 6 2.69 6 6 0 1.01-.25 1.97-.7 2.8l1.46 1.46A7.93 7.93 0 0 0 20 12c0-4.42-3.58-8-8-8Zm0 14c-3.31 0-6-2.69-6-6 0-1.01.25-1.97.7-2.8L5.24 7.74A7.93 7.93 0 0 0 4 12c0 4.42 3.58 8 8 8v3l4-4-4-4v3Z"/></svg>
        </DetailCard>

      </div>
    </div>
  </section>

  <section class="value-strip" aria-label="Value proposition">
    <div class="container value-strip__inner">
      {[
        'Secure AI solutions against evolving cyber risks',
        'Strengthen trust in AI-enabled systems and services',
        'Support safer adoption and operation of artificial intelligence',
      ].map(item => (
        <div class="value-strip__item">
          <span class="value-strip__check">
            <svg viewBox="0 0 24 24" width="14" height="14"><path fill="white" d="M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17Z"/></svg>
          </span>
          <span>{item}</span>
        </div>
      ))}
    </div>
  </section>

  <CTABanner />

</BaseLayout>
