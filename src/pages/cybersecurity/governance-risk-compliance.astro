---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import DetailCard from '../../components/DetailCard.astro';
import CTABanner from '../../components/CTABanner.astro';
---
<BaseLayout
  title="Governance, Risk & Compliance | CyberNovate"
  description="Build robust GRC frameworks aligned to NCA, SAMA, PDPL, NIST, and ISO 27001 with audit-ready documentation and risk programs."
>

  <PageHero eyebrow="Cybersecurity Services" title="Cybersecurity Governance, Risk and Compliance">
    <BreadcrumbNav slot="breadcrumb" crumbs={[
      { label: 'Home', href: '/' },
      { label: 'Cybersecurity', href: '/cybersecurity' },
      { label: 'Governance, Risk & Compliance' },
    ]} />
    <Fragment slot="subtitle">
      <p>A strong cybersecurity foundation begins with effective governance, clear accountability, and a structured compliance program. We help organizations establish and strengthen their governance, risk, and compliance capabilities to align security initiatives with business priorities, regulatory obligations, and industry best practices.</p>
      <p>Our team works closely with leadership, risk owners, and operational teams to design practical frameworks, policies, and controls that improve resilience, support audits, and enable sustainable cybersecurity maturity.</p>
    </Fragment>
  </PageHero>

  <section class="sub-services" aria-labelledby="capabilitiesTitle">
    <div class="container">
      <header class="section-head">
        <span class="eyebrow">Our Capabilities</span>
        <h2 id="capabilitiesTitle" class="section-title">What We Deliver</h2>
      </header>
      <div class="sub-services__grid">

        <DetailCard
          title="Regulatory & Compliance Management"
          description="We support organizations in understanding, interpreting, and implementing regulatory and compliance requirements such as NCA, SAMA, PDPL, NIST, and other relevant standards and obligations. Our approach helps you reduce compliance gaps, prepare for assessments, and maintain ongoing alignment with applicable regulations."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M12 1 3 5v6c0 5.5 3.8 10.7 9 12 5.2-1.3 9-6.5 9-12V5l-9-4Z"/></svg>
        </DetailCard>

        <DetailCard
          title="Policy, Standard and Procedure Development"
          description="We develop clear, effective, and business-aligned cybersecurity policies, standards, and procedures that establish direction, consistency, and accountability across your organization. Our documentation frameworks are tailored to your operating model, risk profile, and compliance requirements."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6Zm-1 1.5L18.5 9H13V3.5ZM8 13h8v2H8v-2Zm0-4h5v2H8V9Zm0 8h8v2H8v-2Z"/></svg>
        </DetailCard>

        <DetailCard
          title="Risk Management"
          description="We help organizations identify, assess, prioritize, and manage cybersecurity risks across business processes, information assets, technologies, and third parties. Our risk management services support stronger decision-making and improved visibility into your security posture."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M12 2 1 21h22L12 2Zm0 4 7.5 13H4.5L12 6Zm-1 5v4h2v-4h-2Zm0 5v2h2v-2h-2Z"/></svg>
        </DetailCard>

        <DetailCard
          title="Cybersecurity Framework Implementation"
          description="We assist in implementing recognized cybersecurity frameworks such as ISO 27001, NIST, and other leading standards. From readiness assessments to control implementation and gap remediation, we help you build a structured, measurable, and auditable security program."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M3 3h8v8H3V3Zm10 0h8v8h-8V3ZM3 13h8v8H3v-8Zm10 4 4-4 4 4-4 4-4-4Z"/></svg>
        </DetailCard>

        <DetailCard
          title="Cybersecurity Program, Strategy & Roadmap Development"
          description="We design cybersecurity programs, strategies, and roadmaps that align with your business objectives, risk appetite, and regulatory environment. Our focus is on delivering a practical path toward improved maturity, better governance, and long-term resilience."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M3 17h6v-7H3v7Zm7 0h4V3h-4v14Zm5 0h6V8h-6v9Z"/></svg>
        </DetailCard>

        <DetailCard
          title="Audit & Compliance"
          description="We help organizations prepare for internal and external audits, assess control effectiveness, address findings, and improve compliance readiness. Our audit support services enhance transparency and strengthen confidence among regulators, auditors, and stakeholders."
        >
          <svg slot="icon" viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17Z"/></svg>
        </DetailCard>

      </div>
    </div>
  </section>

  <section class="value-strip" aria-label="Value proposition">
    <div class="container value-strip__inner">
      {[
        'Strengthen governance and accountability',
        'Improve regulatory compliance and audit readiness',
        'Align security controls with business and risk priorities',
        'Build a sustainable and measurable cybersecurity program',
      ].map(item => (
        <div class="value-strip__item">
          <span class="value-strip__check">
            <svg viewBox="0 0 24 24" width="14" height="14"><path fill="white" d="M9 16.17 4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17Z"/></svg>
          </span>
          <span>{item}</span>
        </div>
      ))}
    </div>
  </section>

  <CTABanner />

</BaseLayout>
